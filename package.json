{
  "name": "api-contract-drift",
  "version": "0.1.0",
  "description": "Detect breaking vs non-breaking changes between two OpenAPI 3.x specs",
  "type": "module",
  "bin": {
    "api-contract-drift": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "openapi-types": "^12.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
